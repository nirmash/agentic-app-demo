{
  "title": "All Controls Test Form",
  "formName": "all_controls_test",
  "sections": [
    {
      "heading": "Text Fields",
      "fields": [
        {
          "type": "text",
          "label": "Full Name",
          "name": "full_name",
          "placeholder": "Enter your name",
          "required": true
        },
        {
          "type": "text",
          "label": "Email Address",
          "name": "email",
          "placeholder": "user@example.com",
          "required": true
        },
        {
          "type": "textarea",
          "label": "Notes",
          "name": "notes",
          "placeholder": "Additional notes or comments",
          "rows": 4
        },
        {
          "type": "password",
          "label": "Secret Code",
          "name": "secret_code",
          "placeholder": "Enter secret code",
          "required": true
        }
      ]
    },
    {
      "heading": "Selection Controls",
      "fields": [
        {
          "type": "dropdown",
          "label": "Country",
          "name": "country",
          "options": [
            "USA",
            "Canada",
            "UK",
            "Germany",
            "Japan"
          ],
          "required": true
        },
        {
          "type": "checkbox",
          "label": "Interests",
          "name": "interests",
          "options": [
            "Sports",
            "Music",
            "Technology",
            "Travel"
          ]
        },
        {
          "type": "checkbox",
          "label": "Agree to Terms",
          "name": "agree_terms",
          "required": true
        },
        {
          "type": "radio",
          "label": "Preferred Contact Method",
          "name": "contact_method",
          "options": [
            "Email",
            "Phone",
            "SMS"
          ]
        }
      ]
    },
    {
      "heading": "Lookup Fields",
      "fields": [
        {
          "type": "lookup",
          "label": "Primary Speaker",
          "name": "primary_speaker",
          "source": "speaker",
          "displayField": "full_name",
          "valueField": "sessionId",
          "required": true
        },
        {
          "type": "lookup",
          "label": "Attending Sessions",
          "name": "attending_sessions",
          "source": "session",
          "displayField": "title",
          "valueField": "sessionId",
          "multiple": true
        }
      ]
    },
    {
      "heading": "Table with Calculated Columns",
      "fields": [
        {
          "type": "table",
          "label": "Team Members",
          "name": "team_members",
          "columns": [
            {
              "header": "First Name",
              "name": "first_name",
              "type": "text",
              "required": true
            },
            {
              "header": "Last Name",
              "name": "last_name",
              "type": "text",
              "required": true
            },
            {
              "header": "Full Name",
              "name": "full_name",
              "type": "calculated",
              "formula": "{first_name} {last_name}"
            },
            {
              "header": "Email",
              "name": "email",
              "type": "text"
            },
            {
              "header": "Handle",
              "name": "handle",
              "type": "calculated",
              "formula": "='@' + email.split('@')[0]"
            },
            {
              "header": "Role",
              "name": "role",
              "type": "dropdown",
              "options": [
                "Developer",
                "Designer",
                "Manager",
                "QA"
              ]
            },
            {
              "header": "Active",
              "name": "active",
              "type": "checkbox"
            }
          ],
          "initialRows": 1
        }
      ]
    },
    {
      "heading": "Navigation & Actions",
      "fields": [
        {
          "type": "link",
          "label": "Register as Speaker →",
          "name": "speaker_link",
          "href": "/speaker/"
        },
        {
          "type": "link",
          "label": "View Attendees →",
          "name": "attendee_link",
          "href": "/attendee/"
        },
        {
          "type": "button",
          "label": "Validate All Fields",
          "name": "validate_btn",
          "events": [
            {
              "event": "click",
              "description": "Validate all required fields",
              "handler": "const form = document.getElementById('main-form'); if (form.checkValidity()) { alert('All fields valid!'); } else { form.reportValidity(); }"
            }
          ]
        },
        {
          "type": "button",
          "label": "Submit Form",
          "name": "submit_btn",
          "events": [
            {
              "event": "click",
              "description": "Submit the form",
              "handler": "document.getElementById('main-form').requestSubmit();"
            }
          ]
        }
      ]
    }
  ]
}